{
  "name": "fitcoach",
  "version": "0.1.0",
  "private": true,
  "packageManager": "pnpm@10.33.0",
  "engines": {
    "node": ">=22.0.0",
    "pnpm": ">=10.0.0"
  },
  "scripts": {
    "dev": "concurrently \"pnpm --filter api dev\" \"pnpm --filter frontend dev\"",
    "build": "pnpm --filter shared build && pnpm --filter api build && pnpm --filter frontend build",
    "lint": "biome check .",
    "lint:fix": "biome check --write .",
    "test": "pnpm --filter shared build && pnpm --filter api test",
    "test:e2e": "pnpm --filter frontend test:e2e",
    "prepare": "husky"
  },
  "devDependencies": {
    "@biomejs/biome": "^1.9.4",
    "concurrently": "^9.1.2",
    "husky": "^9.1.7"
  },
  "pnpm": {
    "overrides": {}
  }
}
