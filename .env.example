# Database
DATABASE_URL=postgresql://fitcoach:changeme@postgres:5432/fitcoach
DB_PASSWORD=changeme

# Auth — generate with: openssl rand -base64 32
JWT_SECRET=
API_KEY_ENCRYPTION_KEY=

# Strava — register at strava.com/settings/api
STRAVA_CLIENT_ID=
STRAVA_CLIENT_SECRET=
STRAVA_REDIRECT_URI=http://localhost:3000/strava/callback
STRAVA_WEBHOOK_VERIFY_TOKEN=any-random-string-you-choose

# Claude API — optional at start, enter via Settings UI after setup
CLAUDE_API_KEY=

# PostHog — free at posthog.com, use EU region
POSTHOG_API_KEY=
POSTHOG_HOST=https://eu.i.posthog.com

# Tailscale — for Strava webhooks in local dev (Tailscale Funnel)
# Generate an auth key at tailscale.com/admin/settings/keys (reusable, ephemeral)
# Funnel must be enabled for your tailnet: tailscale.com/admin/dns → Funnel
TS_AUTHTOKEN=

# Frontend URL — used by API for OAuth redirects
FRONTEND_URL=http://localhost:3001
